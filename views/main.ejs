<main class="flex-1">

<!-- BACKEND -->

<% for (a = 0; a < aptos.length; a++) { %>
  <% let unidad = aptos[a] %>
  <% let indice = listing.find(item => item.propiedad === unidad) %>

  <!-- Necesito encontrar a que indice de LISTING, corresponde el valor unidad -->

<!-- INICIO ANUNCIO -->

<article class="flex flex-col w-full bg-white dark:bg-zinc-900 overflow-hidden mb-1">
    
