    </div>
    
    <!-- ESTA CAJA ES EL TEXTO DEL ANUNCIO -->
    <div class="h-[25%] p-6 flex flex-col justify-center">
      <div class="flex justify-between items-center">
        <div class="space-y-1">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="text-[12px] font-bold tracking-[0.2em] uppercase text-primary"><%= indice.ubicacion %></span>
          </div>
          <h3 class="serif-header text-2xl font-light text-slate-900 dark:text-white"><%= indice.titulo %></h3>
        </div>
        <button class="text-primary/40">
          <span class="material-symbols-outlined text-3xl font-extralight">arrow_forward_ios</span>
        </button>
